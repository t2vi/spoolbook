<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Dashboard"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:controls="using:Spoolbook.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Dashboard.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1E2126"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style Selector="TextBlock.cardTitle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="20">
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"/>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                <controls:StatCard Grid.Column="0" Label="Spools" Value="{Binding SpoolCount}" Command="{Binding ShowSpoolsCommand}"/>
                <controls:StatCard Grid.Column="1" Label="Print Profiles" Value="{Binding ProfileCount}" Command="{Binding ShowProfilesCommand}"/>
                <Border Grid.Column="2" Classes="card">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Filaments" Classes="cardLabel"/>
                        <TextBlock Text="{Binding FilamentCount}" Classes="cardValue"/>
                        <TextBlock Text="{Binding LastFilamentSyncText}" FontSize="11" Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="20">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Filaments by brand" Classes="cardTitle"/>
                        <lvc:CartesianChart Series="{Binding FilamentsByBrandSeries}" LegendPosition="Hidden" FindingStrategy="CompareAll" Height="260"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Filaments by material" Classes="cardTitle"/>
                        <lvc:CartesianChart Series="{Binding FilamentsByMaterialSeries}" LegendPosition="Hidden" FindingStrategy="CompareAll" Height="260"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                <Border Grid.Column="0" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Spools by status" Classes="cardTitle"/>
                        <lvc:PieChart Series="{Binding SpoolsByStatusSeries}" LegendPosition="Hidden" Height="240"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card">
                    <StackPanel>
                        <TextBlock Text="Prints by result" Classes="cardTitle"/>
                        <lvc:PieChart Series="{Binding PrintsByStatusSeries}" LegendPosition="Hidden" Height="240"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
