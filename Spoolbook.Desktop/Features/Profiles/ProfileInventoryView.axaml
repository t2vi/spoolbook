<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Profiles"
             xmlns:models="using:Spoolbook.Desktop.Features.Profiles"
             xmlns:common="using:Spoolbook.Desktop.Common"
             xmlns:controls="using:Spoolbook.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Profiles.ProfileInventoryView"
             x:DataType="vm:ProfileInventoryViewModel">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="All profiles" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Add profile" Click="OnAddProfileClick"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel Width="160">
                    <TextBlock Text="Brand"/>
                    <AutoCompleteBox Text="{Binding BrandFilter}" ItemsSource="{Binding BrandOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="140">
                    <TextBlock Text="Material"/>
                    <AutoCompleteBox Text="{Binding MaterialFilter}" ItemsSource="{Binding MaterialOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <Button Content="Filter" Command="{Binding ApplyFiltersCommand}" VerticalAlignment="Bottom"/>
            </StackPanel>
        </StackPanel>

        <controls:Pagination DockPanel.Dock="Bottom" Margin="0,12,0,0"
                              Page="{Binding Page}" TotalPages="{Binding TotalPages}" PageSize="{Binding PageSize}"
                              PreviousCommand="{Binding PreviousPageCommand}" NextCommand="{Binding NextPageCommand}"/>

        <DataGrid ItemsSource="{Binding Profiles}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  Background="#1E2124"
                  CornerRadius="4">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Filament.Brand}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Filament" Command="{Binding SortByCommand}" CommandParameter="Filament"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Name" Command="{Binding SortByCommand}" CommandParameter="Name"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Scope" Binding="{Binding SpoolId}" Width="*"/>
                <DataGridTextColumn Binding="{Binding NozzleTempC}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Nozzle" Command="{Binding SortByCommand}" CommandParameter="NozzleTempC"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:PrintProfile">
                            <Button Content="Edit" Margin="4,0" Click="OnEditProfileClick" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
