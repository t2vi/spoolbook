<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Prints"
             xmlns:models="using:Spoolbook.Desktop.Features.Prints"
             xmlns:common="using:Spoolbook.Desktop.Common"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Prints.PrintInventoryView"
             x:DataType="vm:PrintInventoryViewModel">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="All prints" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Add print" Click="OnAddPrintClick"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel Width="160">
                    <TextBlock Text="Brand"/>
                    <AutoCompleteBox Text="{Binding BrandFilter}" ItemsSource="{Binding BrandOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="140">
                    <TextBlock Text="Material"/>
                    <AutoCompleteBox Text="{Binding MaterialFilter}" ItemsSource="{Binding MaterialOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="120">
                    <TextBlock Text="Status"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}" HorizontalAlignment="Stretch"/>
                </StackPanel>
                <Button Content="Filter" Command="{Binding ApplyFiltersCommand}" VerticalAlignment="Bottom"/>
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="Previous" Command="{Binding PreviousPageCommand}"/>
            <TextBlock Text="{Binding Page}" VerticalAlignment="Center"/>
            <TextBlock Text="/" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center"/>
            <Button Content="Next" Command="{Binding NextPageCommand}"/>
            <TextBlock Text="Per page" VerticalAlignment="Center" Margin="12,0,0,0"/>
            <ComboBox ItemsSource="{x:Static common:PageSizes.Options}" SelectedItem="{Binding PageSize}"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Prints}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  Background="#1E2124"
                  CornerRadius="4">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding StartedAt}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Started" Command="{Binding SortByCommand}" CommandParameter="StartedAt"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Spool" Binding="{Binding Spool}" Width="*"/>
                <DataGridTextColumn Header="Profile" Binding="{Binding Profile.Name}" Width="*"/>
                <DataGridTextColumn Binding="{Binding Printer.Name}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Printer" Command="{Binding SortByCommand}" CommandParameter="Printer"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Status}" Width="Auto">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Status" Command="{Binding SortByCommand}" CommandParameter="Status"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Ambient" Width="Auto">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0}°C / {1}%">
                            <Binding Path="AmbientTempC"/>
                            <Binding Path="AmbientHumidityPct"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Print">
                            <Button Content="Edit" Margin="4,0" Click="OnEditPrintClick" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
