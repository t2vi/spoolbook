<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Settings"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Settings.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

        <TabControl>
            <TabItem Header="General">
                <ContentControl Content="{Binding General}"/>
            </TabItem>
            <TabItem Header="Filaments">
                <ContentControl Content="{Binding Filaments}"/>
            </TabItem>
            <TabItem Header="Filament colors">
                <ContentControl Content="{Binding Colors}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
