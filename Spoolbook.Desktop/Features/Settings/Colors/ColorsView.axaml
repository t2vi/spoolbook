<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Settings.Colors"
             xmlns:models="using:Spoolbook.Desktop.Features.Settings.Colors"
             xmlns:local="using:Spoolbook.Desktop.Converters"
             xmlns:common="using:Spoolbook.Desktop.Common"
             xmlns:controls="using:Spoolbook.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Settings.Colors.ColorsView"
             x:DataType="vm:ColorsViewModel">
    <DockPanel Margin="0,12,0,0">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Colors are added automatically as you add filaments (known or your own) — edit hex codes here." FontStyle="Italic" VerticalAlignment="Center"/>
                <Button Content="Add color" Click="OnAddColorClick"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel Width="160">
                    <TextBlock Text="Name"/>
                    <AutoCompleteBox Text="{Binding NameFilter}" ItemsSource="{Binding NameOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <Button Content="Filter" Command="{Binding ApplyFiltersCommand}" VerticalAlignment="Bottom"/>
            </StackPanel>
        </StackPanel>

        <controls:Pagination DockPanel.Dock="Bottom" Margin="0,8,0,0"
                              Page="{Binding Page}" TotalPages="{Binding TotalPages}" PageSize="{Binding PageSize}"
                              PreviousCommand="{Binding PreviousPageCommand}" NextCommand="{Binding NextPageCommand}"/>

        <DataGrid ItemsSource="{Binding Colors}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  Background="#1E2124"
                  CornerRadius="4">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FilamentColor">
                            <Border Width="20" Height="20" CornerRadius="4" BorderThickness="1" Margin="8,0"
                                    BorderBrush="{Binding Hex, Converter={x:Static local:HexToBorderBrushConverter.Instance}}"
                                    Background="{Binding Hex, Converter={x:Static local:HexToBrushConverter.Instance}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Name" Command="{Binding SortByCommand}" CommandParameter="Name"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Hex}" Width="100">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Hex" Command="{Binding SortByCommand}" CommandParameter="Hex"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:FilamentColor">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Edit" Click="OnEditColorClick" Tag="{Binding}"/>
                                <Button Content="Delete"
                                        Command="{Binding $parent[DataGrid].((vm:ColorsViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
