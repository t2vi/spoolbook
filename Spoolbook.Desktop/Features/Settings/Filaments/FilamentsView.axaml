<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Spoolbook.Desktop.Features.Settings.Filaments"
             xmlns:models="using:Spoolbook.Desktop.Features.Settings.Filaments"
             xmlns:local="using:Spoolbook.Desktop.Converters"
             xmlns:common="using:Spoolbook.Desktop.Common"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:controls="using:Spoolbook.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Spoolbook.Desktop.Features.Settings.Filaments.FilamentsView"
             x:DataType="vm:FilamentsViewModel">
    <DockPanel Margin="0,12,0,0">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Filament types you can put on a spool — seeded from market research, plus anything you add yourself. Colors are picked from (and added to) the Filament colors list." FontStyle="Italic" VerticalAlignment="Center" MaxWidth="500" TextWrapping="Wrap"/>
                <Button Content="Add filament" Click="OnAddFilamentClick"/>
                <Button Content="Sync filament catalog" Command="{Binding SyncCatalogCommand}" IsEnabled="{Binding !IsSyncing}"/>
            </StackPanel>

            <TextBlock Text="{Binding SyncStatusMessage}" IsVisible="{Binding SyncStatusMessage, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel Width="160">
                    <TextBlock Text="Brand"/>
                    <AutoCompleteBox Text="{Binding BrandFilter}" ItemsSource="{Binding BrandOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="140">
                    <TextBlock Text="Material"/>
                    <AutoCompleteBox Text="{Binding MaterialFilter}" ItemsSource="{Binding MaterialOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="120">
                    <TextBlock Text="Variant"/>
                    <AutoCompleteBox Text="{Binding VariantFilter}" ItemsSource="{Binding VariantOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <StackPanel Width="140">
                    <TextBlock Text="Color"/>
                    <AutoCompleteBox Text="{Binding ColorFilter}" ItemsSource="{Binding ColorFilterOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
                </StackPanel>
                <Button Content="Filter" Command="{Binding ApplyFiltersCommand}" VerticalAlignment="Bottom"/>
            </StackPanel>
        </StackPanel>

        <controls:Pagination DockPanel.Dock="Bottom" Margin="0,8,0,0"
                              Page="{Binding Page}" TotalPages="{Binding TotalPages}" PageSize="{Binding PageSize}"
                              PreviousCommand="{Binding PreviousPageCommand}" NextCommand="{Binding NextPageCommand}"/>

        <DataGrid ItemsSource="{Binding Filaments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  Background="#1E2124"
                  CornerRadius="4">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Brand}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Brand" Command="{Binding SortByCommand}" CommandParameter="Brand"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Material}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Material" Command="{Binding SortByCommand}" CommandParameter="Material"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Variant}" Width="*">
                    <DataGridTextColumn.Header>
                        <Button Classes="tableHeader" Content="Variant" Command="{Binding SortByCommand}" CommandParameter="Variant"/>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.Header>
                        <Button Classes="tableHeader" Content="Color" Command="{Binding SortByCommand}" CommandParameter="Color"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Filament">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0">
                                <Border Width="14" Height="14" CornerRadius="3" BorderThickness="1"
                                        BorderBrush="{Binding Color, Converter={x:Static local:ColorSwatchBorderConverter.Instance}}"
                                        Background="{Binding Color, Converter={x:Static local:ColorSwatchConverter.Instance}}"/>
                                <TextBlock Text="{Binding Color}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Filament">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="Edit" Click="OnEditFilamentClick" Tag="{Binding}"/>
                                <Button Content="Delete"
                                        Command="{Binding $parent[DataGrid].((vm:FilamentsViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
