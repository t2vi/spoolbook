<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Spoolbook.Desktop.Features.Settings.Filaments"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:local="using:Spoolbook.Desktop.Converters"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Spoolbook.Desktop.Features.Settings.Filaments.FilamentEditWindow"
        x:DataType="vm:FilamentEditViewModel"
        Title="{Binding PageTitle}"
        Width="480" SizeToContent="Height"
        Background="#26292C"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <StackPanel Width="160">
                <TextBlock Text="Brand"/>
                <TextBox Text="{Binding Brand}"/>
            </StackPanel>
            <StackPanel Width="140">
                <TextBlock Text="Material"/>
                <TextBox Text="{Binding Material}"/>
            </StackPanel>
            <StackPanel Width="120">
                <TextBlock Text="Variant"/>
                <TextBox Text="{Binding Variant}"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <StackPanel Width="200">
                <TextBlock Text="Color"/>
                <AutoCompleteBox Text="{Binding Color}" ItemsSource="{Binding ColorNameOptions}" FilterMode="Contains" MinimumPrefixLength="0"/>
            </StackPanel>
            <StackPanel Width="32">
                <TextBlock Text=" "/>
                <Border Width="28" Height="28" CornerRadius="4" BorderThickness="1"
                        BorderBrush="{Binding SwatchHex, Converter={x:Static local:HexToBorderBrushConverter.Instance}}"
                        Background="{Binding SwatchHex, Converter={x:Static local:HexToBrushConverter.Instance}}"/>
            </StackPanel>
        </StackPanel>
        <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"/>
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            <Button Content="Save" Command="{Binding SaveCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>
